# AI service (см. docker-compose.yml → ai)
AI_PROVIDER=lmstudio
AI_TEMPERATURE=0.7
# true — ReAct tool-calling (lmstudio/openai); false — только structured parse_intent
AI_TASKS_USE_AGENT=true
# AI_REQUEST_LOG_DIR=/app/logs
# AI_REQUEST_LOG_FILE=requests.jsonl
# Ollama (локально на хосте)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# LM Studio (см. README: Serve on Local Network / lms server start --bind 0.0.0.0)
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_API_KEY=lm-studio

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
